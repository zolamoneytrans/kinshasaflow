rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 1. Autorisation universelle en lecture pour tous les fichiers
    match /{allPaths=**} {
      allow read: if true;
    }

    // 2. Règle prioritaire pour le dossier tourisme
    // Autorise l'admin principal ET l'admin tourisme spécifique
    match /tourism/{allPaths=**} {
      allow write: if request.auth != null && 
                   (request.auth.token.email == 'drnduwa@gmail.com' || 
                    request.auth.token.email == 'contact.congonamotema@gmail.com');
    }
    
    // 3. Gestion des avatars personnels
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 4. Gestion des vidéos communautaires
    match /videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 5. Règle de secours pour l'administrateur principal sur toute la structure
    match /{allPaths=**} {
      allow write: if request.auth != null && 
                   request.auth.token.email == 'drnduwa@gmail.com';
    }
  }
}