rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. Accès public en lecture pour tous les fichiers (images, vidéos, audios)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Fonctions de vérification
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'drnduwa@gmail.com' ||
        request.auth.token.email == 'contact.congonamotema@gmail.com'
      );
    }

    // 2. Règles spécifiques par dossier
    
    // Salon de discussion (Chat)
    match /chat/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) || isAdmin();
    }

    // Photos de profil (Avatars)
    match /avatars/{userId} {
      allow write: if isOwner(userId) || isAdmin();
    }

    // Signalements de dangers (Hazards)
    match /hazards/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) || isAdmin();
    }

    // Flux Vidéos (Social)
    match /videos/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) || isAdmin();
    }

    // Dossier Tourisme (Admin uniquement)
    match /tourism/{allPaths=**} {
      allow write: if isAdmin();
    }

    // 3. Fallback global pour l'administrateur système
    match /{allPaths=**} {
      allow write: if isAdmin();
    }
  }
}