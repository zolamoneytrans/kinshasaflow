rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. Accès public en lecture pour tous les fichiers
    match /{allPaths=**} {
      allow read: if true;
    }

    // 2. Fonctions de sécurité
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'drnduwa@gmail.com' ||
        request.auth.token.email == 'contact.congonamotema@gmail.com'
      );
    }

    // 3. Règle universelle pour les dossiers utilisateurs (chat, avatars, hazards, videos)
    // Cette règle autorise l'écriture si l'UID de l'utilisateur correspond au nom du dossier
    match /{folder}/{userId}/{allPaths=**} {
      allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
    }

    // 4. Dossier spécifique au Tourisme
    match /tourism/{allPaths=**} {
      allow write: if isAdmin();
    }

    // 5. Autorisation globale pour le super-admin (sécurité supplémentaire)
    match /{allPaths=**} {
      allow write: if isSignedIn() && request.auth.token.email == 'drnduwa@gmail.com';
    }
  }
}