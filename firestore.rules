rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'drnduwa@gmail.com';
    }

    // --- COLLECTION RULES ---

    /** Rules for road condition reports */
    match /road_condition_reports/{reportId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // allow votes
      allow delete: if isAdmin();
    }

    /** Daily Traffic Audit & Insights */
    match /daily_traffic_reports/{reportId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /traffic_insights/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /** Application Settings */
    match /app_settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** Rules for user profiles and balances */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /star_transactions/{transactionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if false;
      }

      match /transport_subscriptions/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /pushSubscriptions/{id} {
        allow read, write: if isOwner(userId);
      }

      match /fcmTokens/{id} {
        allow read, write: if isOwner(userId);
      }
    }
    
    /** Community & Content */
    match /notifications/{id} { allow read: if true; allow create: if isSignedIn(); allow update, delete: if isAdmin(); }
    match /events/{id} { 
      allow read, create: if isSignedIn(); 
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId); 
      match /comments/{commentId} { allow read, create: if isSignedIn(); }
    }
    match /videos/{id} { 
      allow read: if true; 
      allow create: if isSignedIn(); 
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      match /comments/{commentId} { allow read, create: if isSignedIn(); }
    }
    match /adverts/{id} { allow read: if true; allow write: if isAdmin(); }

    /** Business Services */
    match /logements/{id} { allow read: if true; allow write: if isAdmin(); }
    match /logement_applications/{id} { allow read: if isAdmin(); allow create: if isSignedIn(); }
    match /tourism_events/{id} { allow read: if true; allow write: if isAdmin() || request.auth.token.email == 'contact.congonamotema@gmail.com'; }
    match /tourism_bookings/{id} { allow read: if isAdmin() || request.auth.token.email == 'contact.congonamotema@gmail.com'; allow create: if isSignedIn(); }
    match /car_bookings/{id} { allow read: if isAdmin(); allow create: if isSignedIn(); }
    match /inquiries/{id} { allow read: if isAdmin(); allow create: if isSignedIn(); }
    match /police_reports/{id} { allow read: if true; allow create: if isSignedIn(); allow delete: if isAdmin(); }
  }
}