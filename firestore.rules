rules_version = '2';

/**
 * KINSHASAFLOW FIRESTORE SECURITY RULES
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a strict User-Ownership and Administrative-Control model. 
 * Authorization is the primary focus: we ensure that private user data is only 
 * accessible by the owner, while global configuration and monetization data 
 * are read-only for users and manageable only by administrators.
 *
 * DATA STRUCTURE:
 * 1. User-Centric Data: Nested under `/users/{userId}/`. This includes the user 
 *    profile, star balances, generated ID assets, and transaction history.
 * 2. Administrative Controls: Managed via a flat `/admin_roles/` collection 
 *    (Database-Backed Access Control).
 * 3. Global Configurations: Collections like `/id_templates/` and `/star_packages/` 
 *    provide the app's catalog, accessible to all signed-in users.
 *
 * KEY SECURITY DECISIONS:
 * - Denormalization for Authorization: To ensure performant rules, the `userId` 
 *   is enforced both in the path and as a field within subcollection documents.
 * - Transaction Integrity: Star transactions are immutable. Once created, they 
 *   cannot be updated or deleted by users, preserving financial history.
 * - Prototyping Flexibility: While access control is rigid, the specific 
 *   schema of content fields is not enforced to allow for rapid development.
 * - Admin Supremacy: Global metadata is protected by an `isAdmin()` check 
 *   referencing the `/admin_roles/` collection.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    /* --- STEP 1: ANALYSIS & SYNTHESIS ---
     * 1. Ownership Pattern: Applied to `/users/{userId}` and its subcollections.
     * 2. DBAC Pattern: Applied to `/admin_roles` and all global metadata collections.
     * 3. Public Read/Admin Write Pattern: Applied to Templates, Packages, and Operators.
     * 4. Immutable History Pattern: Applied to `star_transactions`.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the document exists and the user is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user has a document in the admin_roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles and star balances.
     * @path /users/{userId}
     * @allow (get) If the user is the owner.
     * @deny (update) If the user attempts to change their own 'id' field.
     * @principle Restricts access to a user's own data tree and ensures ID consistency.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      /**
       * @description Rules for specific IDs generated by the user.
       * @path /users/{userId}/generated_ids/{generatedId}
       * @allow (create) If the user is the owner and the internal userId matches the path.
       * @deny (update) If the user attempts to change the owner of the document.
       * @principle Enforces path-based ownership and relational integrity.
       */
      match /generated_ids/{generatedId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      /**
       * @description Rules for star transaction logs.
       * @path /users/{userId}/star_transactions/{transactionId}
       * @allow (create) If the user is the owner.
       * @deny (update, delete) Transactions are immutable and cannot be modified or removed.
       * @principle Ensures financial audit trails cannot be tampered with by users.
       */
      match /star_transactions/{transactionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if false;
      }
    }

    /**
     * @description Administrative role assignments.
     * @path /admin_roles/{userId}
     * @allow (read) Only if the requester is an admin.
     * @principle Database-Backed Access Control (DBAC) for system management.
     */
    match /admin_roles/{userId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Catalog of available ID templates.
     * @path /id_templates/{templateId}
     * @allow (read) Any signed-in user.
     * @deny (write) Non-admin users.
     * @principle Global read access for product catalog with admin-only management.
     */
    match /id_templates/{templateId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Available Star packages for purchase.
     * @path /star_packages/{packageId}
     * @allow (read) Any signed-in user.
     * @principle Global read access for monetization options.
     */
    match /star_packages/{packageId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Mobile Money operators supported in RDC.
     * @path /mobile_money_operators/{operatorId}
     * @allow (read) Any signed-in user.
     * @principle Provides branding and routing info for payment flows.
     */
    match /mobile_money_operators/{operatorId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Definitions of ways to earn free stars.
     * @path /star_earning_action_types/{actionTypeId}
     * @allow (read) Any signed-in user.
     * @principle Transparency regarding reward mechanisms.
     */
    match /star_earning_action_types/{actionTypeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Definitions of premium features requiring stars.
     * @path /star_spending_feature_types/{featureTypeId}
     * @allow (read) Any signed-in user.
     * @principle Defines the cost of premium app functionality.
     */
    match /star_spending_feature_types/{featureTypeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}