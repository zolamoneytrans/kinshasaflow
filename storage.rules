rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. Accès public en lecture pour tous les fichiers
    match /{allPaths=**} {
      allow read: if true;
    }

    // 2. Fonctions de sécurité
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'drnduwa@gmail.com' ||
        request.auth.token.email == 'contact.congonamotema@gmail.com'
      );
    }

    // 3. Règles spécifiques par dossier

    // Chat Communautaire : Autorise l'écriture si propriétaire ou admin
    match /chat/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Photos de profil
    match /avatars/{userId} {
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Signalements Dangers (Hazard Map)
    match /hazards/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Vidéo Feed
    match /videos/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) || isAdmin();
    }

    // Tourisme
    match /tourism/{allPaths=**} {
      allow write: if isAdmin();
    }

    // Autorisation globale pour le super-admin sur tout le bucket
    match /{allPaths=**} {
      allow write: if isSignedIn() && request.auth.token.email == 'drnduwa@gmail.com';
    }
  }
}