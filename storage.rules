rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Accès en lecture publique pour tous les fichiers (images, vidéos, audios)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Fonction d'aide pour l'administrateur
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'drnduwa@gmail.com';
    }

    // Règle pour le Salon de discussion (Chat)
    // Permet à l'utilisateur d'écrire dans SON dossier ou à l'admin
    match /chat/{userId}/{allPaths=**} {
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Règle pour les Photos de profil (Avatars)
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Règle pour les Signalements de dangers (Hazards)
    match /hazards/{userId}/{allPaths=**} {
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Règle pour le Flux Vidéos (Social)
    match /videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Règle pour le Dossier Tourisme
    match /tourism/{allPaths=**} {
      allow write: if request.auth != null && (
        isAdmin() || 
        request.auth.token.email == 'contact.congonamotema@gmail.com'
      );
    }

    // Sécurité globale de secours pour l'admin sur tout le bucket
    match /{allPaths=**} {
      allow write: if isAdmin();
    }
  }
}