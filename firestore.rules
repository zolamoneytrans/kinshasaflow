/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model for user-specific data, while
 * allowing broader access for public-facing data like traffic events.
 *
 * Data Structure: The data is organized into three main top-level collections:
 * 1. `/users`: Contains private user documents and their subcollections.
 * 2. `/idTemplates`: A public, read-only collection of templates available to all authenticated users.
 * 3. `/events`: A public collection of user-reported traffic incidents.
 *
 * Key Security Decisions:
 * - User data is private: Access to `/users/{userId}` and all its subcollections is restricted to the
 *   authenticated user whose UID matches the `{userId}` in the path.
 * - No user listing: To protect user privacy, it is impossible to list all documents in the `/users` collection.
 * - Templates are read-only for non-admins: The `/idTemplates` collection is intended to be managed by administrators.
 *   Write operations are disabled for regular users.
 * - Events are publicly readable: All users (authenticated or not) can read event data to stay informed.
 * - Event creation is for authenticated users: Any signed-in user can report an event.
 * - Event comments are publicly readable but writes are restricted: Similar to events, comments can be read by
 *   any user, but only created by authenticated users, with ownership enforced.
 *
 * Denormalization for Authorization: The `GeneratedId`, `EventReport`, and `Comment` documents contain a `userId` field.
 * The rules enforce on creation that this field matches the creator's UID. This ensures a permanent and
 * easily verifiable link to the owner without needing extra database reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to improve readability and maintainability of rules.

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for update and delete
     * operations to prevent acting on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    /**
     * Checks if the signed-in user is an admin.
     */
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'drnduwa@gmail.com';
    }

    /**
     * @description   Rules for the User collection. Each document stores a user's profile.
     * @path          /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // CRITICAL: Prevent listing of all users.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description   Rules for a user's generated IDs.
       * @path          /users/{userId}/generatedIds/{generatedId}
       */
      match /generatedIds/{generatedId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
      
      /**
       * @description   Rules for a user's push notification subscriptions.
       * @path          /users/{userId}/pushSubscriptions/{subscriptionId}
       */
      match /pushSubscriptions/{subscriptionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.endpoint != '';
        allow update: if false;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    /**
     * @description   Rules for the ID Templates collection. Templates are public and read-only for all signed-in users.
     * @path          /idTemplates/{idTemplateId}
     */
    match /idTemplates/{idTemplateId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false; // Writes are disabled; templates are managed by admins.
      allow update: if false; // Writes are disabled; templates are managed by admins.
      allow delete: if false; // Writes are disabled; templates are managed by admins.
    }

    /**
     * @description   Rules for the Events collection. Events are publicly readable.
     * @path          /events/{eventId}
     */
    match /events/{eventId} {
      allow get, list: if true; // Publicly readable by anyone
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isExistingOwner(request.auth.uid) && resource.data.userId == request.auth.uid;

      /**
       * @description   Rules for the comments subcollection within an event.
       * @path          /events/{eventId}/comments/{commentId}
       */
      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        // Allow users to update or delete their own comments
        allow update, delete: if isExistingOwner(request.auth.uid) && resource.data.userId == request.auth.uid;
      }
    }
    
    /**
     * @description   Rules for the Videos collection.
     * @path          /videos/{videoId}
     */
    match /videos/{videoId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(request.auth.uid) && resource.data.userId == request.auth.uid; // for likes
      allow delete: if isExistingOwner(request.auth.uid) && resource.data.userId == request.auth.uid;

      /**
       * @description   Rules for the comments subcollection within a video.
       * @path          /videos/{videoId}/comments/{commentId}
       */
      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isExistingOwner(request.auth.uid) && resource.data.userId == request.auth.uid;
      }
    }
    
    /**
     * @description   Rules for the Announcements collection. Publicly readable, admin-only write.
     * @path          /annonces/{annonceId}
     */
    match /annonces/{annonceId} {
      allow read: if true;
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    /**
     * @description   Rules for the Logements collection. Publicly readable, admin-only write.
     * @path          /logements/{logementId}
     */
    match /logements/{logementId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
