
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the IDGenius application, including their personal information and Star balance for the monetization system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for login and notifications.",
          "format": "email"
        },
        "currentStarsBalance": {
          "type": "number",
          "description": "The current number of Stars available for the user to spend."
        },
        "totalStarsEarned": {
          "type": "number",
          "description": "The cumulative total of Stars the user has earned through free actions."
        },
        "totalStarsPurchased": {
          "type": "number",
          "description": "The cumulative total of Stars the user has acquired through purchases."
        },
        "totalStarsUsed": {
          "type": "number",
          "description": "The cumulative total of Stars the user has spent on premium features."
        },
        "lastLoginTimestamp": {
          "type": "string",
          "description": "The timestamp of the user's last successful login, used for calculating login streaks.",
          "format": "date-time"
        },
        "consecutiveLoginDays": {
          "type": "number",
          "description": "The number of consecutive days the user has logged in, used for awarding streak bonuses."
        },
        "referralCode": {
          "type": "string",
          "description": "A unique code assigned to the user, which can be shared to refer new users."
        },
        "referredByUserId": {
          "type": "string",
          "description": "Reference to the User who referred this user to the application. (Relationship: User 1:N User)"
        },
        "isProfileComplete": {
          "type": "boolean",
          "description": "Indicates whether the user has completed all required profile information, a condition for earning Stars."
        }
      },
      "required": [
        "id",
        "email",
        "currentStarsBalance",
        "totalStarsEarned",
        "totalStarsPurchased",
        "totalStarsUsed",
        "lastLoginTimestamp",
        "consecutiveLoginDays",
        "referralCode",
        "isProfileComplete"
      ]
    },
    "AppNotification": {
      "title": "AppNotification",
      "type": "object",
      "description": "Global notifications for real-time engagement.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["user_joined", "traffic_report", "video_added", "system_alert"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "link": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "type", "title", "message", "timestamp"]
    },
    "AppNavigationSettings": {
      "title": "AppNavigationSettings",
      "type": "object",
      "description": "Controls the visibility of navigation items in the app.",
      "properties": {
        "reports": { "type": "boolean" },
        "liveTraffic": { "type": "boolean" },
        "map": { "type": "boolean" },
        "assistant": { "type": "boolean" },
        "notifications": { "type": "boolean" },
        "myStars": { "type": "boolean" },
        "report": { "type": "boolean" },
        "police": { "type": "boolean" },
        "routes": { "type": "boolean" },
        "announcements": { "type": "boolean" },
        "logement": { "type": "boolean" },
        "transport": { "type": "boolean" },
        "carRental": { "type": "boolean" },
        "tourism": { "type": "boolean" },
        "events": { "type": "boolean" },
        "videos": { "type": "boolean" },
        "kinshasa": { "type": "boolean" },
        "restaurants": { "type": "boolean" },
        "contact": { "type": "boolean" },
        "share": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profiles and their cumulative star statistics.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            }
          ]
        }
      },
      {
        "path": "/app_settings/navigation",
        "definition": {
          "entityName": "AppNavigationSettings",
          "schema": {
            "$ref": "#/backend/entities/AppNavigationSettings"
          },
          "description": "Global application navigation configuration."
        }
      },
      {
        "path": "/notifications/{id}",
        "definition": {
          "entityName": "AppNotification",
          "schema": {
            "$ref": "#/backend/entities/AppNotification"
          },
          "description": "Global notification feed."
        }
      }
    ]
  }
}
