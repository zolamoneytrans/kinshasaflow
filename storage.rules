rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Accès en lecture publique pour tous les fichiers (images, vidéos, audios)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Règle de secours : l'administrateur a tous les droits d'écriture
    // On vérifie l'UID ou l'email pour plus de robustesse
    match /{allPaths=**} {
      allow write: if request.auth != null && (
        request.auth.token.email == 'drnduwa@gmail.com' ||
        request.auth.uid == 'kTFPpztAXQUgLVUAX8M4A2CwMdE3'
      );
    }

    // Permissions spécifiques par dossier utilisateur
    // Dossier Chat
    match /chat/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Dossier Avatars
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Dossier Signalements de dangers (Hazards)
    match /hazards/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Dossier Flux Vidéos (Social)
    match /videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Dossier Tourisme (Accès Partenaire)
    match /tourism/{allPaths=**} {
      allow write: if request.auth != null && (
        request.auth.token.email == 'contact.congonamotema@gmail.com' ||
        request.auth.token.email == 'drnduwa@gmail.com'
      );
    }
  }
}