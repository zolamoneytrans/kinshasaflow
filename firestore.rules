
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'drnduwa@gmail.com';
    }

    // --- COLLECTION RULES ---

    /** Rules for road condition reports */
    match /road_condition_reports/{reportId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // allow votes
      allow delete: if isAdmin();
    }

    /** Application Settings */
    match /app_settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** Rules for user profiles and balances */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /star_transactions/{transactionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if false;
      }

      match /transport_subscriptions/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /pushSubscriptions/{id} {
        allow read, write: if isOwner(userId);
      }

      match /fcmTokens/{id} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ... existing rules for other collections
    match /notifications/{id} { allow read: if isSignedIn(); allow create: if isSignedIn(); allow update, delete: if isAdmin(); }
    match /events/{id} { allow read, create: if isSignedIn(); allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId); }
  }
}
