rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. Accès public en lecture pour tous les fichiers
    match /{allPaths=**} {
      allow read: if true;
    }

    // 2. Fonctions de commodité
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'drnduwa@gmail.com' ||
        request.auth.token.email == 'contact.congonamotema@gmail.com'
      );
    }

    // 3. Règles par dossier (Propriétaire ou Admin)

    // Dossier Chat Communautaire
    match /chat/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Dossier Photos de profil
    match /avatars/{userId} {
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Dossier Signalements Dangers
    match /hazards/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Dossier Vidéo Feed
    match /videos/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) || isAdmin();
    }

    // Dossier Tourisme
    match /tourism/{allPaths=**} {
      allow write: if isAdmin();
    }

    // 4. Permission globale d'écriture pour le super-admin
    match /{allPaths=**} {
      allow write: if isSignedIn() && request.auth.token.email == 'drnduwa@gmail.com';
    }
  }
}