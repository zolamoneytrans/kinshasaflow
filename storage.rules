rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. LECTURE : Accès public pour tous les médias
    match /{allPaths=**} {
      allow read: if true;
    }

    // 2. ÉCRITURE : Règles consolidées pour éviter les conflits d'autorisation
    match /{allPaths=**} {
      allow write: if request.auth != null && (
        // Accès total pour l'administrateur
        request.auth.token.email == 'drnduwa@gmail.com' ||
        request.auth.uid == 'kTFPpztAXQUgLVUAX8M4A2CwMdE3' ||
        
        // Accès propriétaire pour les dossiers de services (chat, avatars, hazards, videos)
        // La structure attendue est /{service}/{userId}/...
        (
          (request.path[0] == 'chat' || 
           request.path[0] == 'avatars' || 
           request.path[0] == 'hazards' || 
           request.path[0] == 'videos') && 
          request.auth.uid == request.path[1]
        ) ||
        
        // Accès partenaire pour le tourisme
        (
          request.path[0] == 'tourism' && 
          request.auth.token.email == 'contact.congonamotema@gmail.com'
        )
      );
    }
  }
}