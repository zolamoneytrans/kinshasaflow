rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Fonction universelle pour identifier l'administrateur
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'drnduwa@gmail.com';
    }

    // Autoriser la lecture publique partout pour le contenu du site
    match /{allPaths=**} {
      allow read: if true;
      // Seul l'admin peut modifier ou supprimer des fichiers
      allow write: if isAdmin();
    }

    // Autorisations spécifiques pour les dossiers (sécurité renforcée)
    match /tourism/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /logements/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}