rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Règle d'accès universelle pour l'administrateur
    // On vérifie l'email de manière plus flexible pour éviter les rejets liés à la casse ou au champ exact
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
                   (request.auth.token.email == 'drnduwa@gmail.com' || 
                    request.auth.token.email_verified == true && request.auth.token.email == 'drnduwa@gmail.com');
    }

    // Règles spécifiques par dossier (en secours)
    match /tourism/{eventId}/{fileName} {
      allow write: if request.auth != null && request.auth.token.email == 'drnduwa@gmail.com';
    }
    
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}