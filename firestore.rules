/**
 * Core Philosophy: This ruleset implements a security model that combines role-based access control (RBAC) with
 * a strict user-ownership model. It provides public read access to shared resources (templates) for all authenticated
 * users while ensuring that user-generated data is private and accessible only by its creator. Administrative
 * privileges are managed by checking the user's email address.
 *
 * Data Structure: The data is organized into several main areas:
 * 1. /id_templates/{templateId}: A top-level collection of ID card templates, readable by all signed-in users.
 * 2. /users/{userId}/...: User-specific data nested under a path that includes the owner's UID.
 * 3. /logements/{logementId}: Publicly readable apartment listings.
 * 4. /logement_applications/{applicationId}: Applications for apartments, readable by admin.
 *
 * Key Security Decisions:
 * - Admin Access: Administrative privileges are determined by checking if the user's email is 'drnduwa@gmail.com'.
 * - User Data Privacy: User-generated data is stored in subcollections under their unique user ID (/users/{userId}/...).
 *   This path-based ownership prevents any user from accessing another user's private data.
 * - User Enumeration: Listing documents in the top-level /users collection is explicitly disallowed to prevent scraping user data.
 * - Prototyping Flexibility: Data validation is strictly limited to fields essential for authorization (e.g., `creatorUserId`).
 *   Other data shapes are not enforced, allowing the front-end application schema to evolve rapidly without rule changes.
 *
 * Denormalization for Authorization:
 * - The `GeneratedID` documents under `/users/{userId}/generated_ids/{generatedId}` contain a `creatorUserId` field.
 *   This field is validated against the `{userId}` in the path, creating a robust and performant ownership check that does not
 *   require any extra document reads (`get()` calls).
 *
 * Structural Segregation:
 * - Publicly readable templates (`id_templates`) are in a separate top-level collection from private, user-owned data.
 *   This separation ensures that list operations are simple, secure, and performant.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    // =================================

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the requesting user's UID matches the provided userId.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the document being accessed already exists in Firestore.
     * Crucial for protecting against writes on non-existent documents.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * A convenience function that combines an ownership check with an
     * existence check. Used for all state-changing operations (update, delete).
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    /**
     * Checks if the requesting user has administrative privileges by checking their email address.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'drnduwa@gmail.com';
    }

    /**
     * On create, validates that the new 'GeneratedID' document contains a
     * 'creatorUserId' field that correctly matches the user's ID from the path.
     */
    function hasValidGeneratedIdDataOnCreate(userId) {
      return request.resource.data.creatorUserId == userId;
    }
    
    /**
     * On create, validates that a new inquiry is from the correct user and has all required fields.
     */
    function hasValidInquiryDataOnCreate() {
      let data = request.resource.data;
      return data.userId == request.auth.uid
        && data.fullName is string && data.fullName.size() > 2
        && data.phone is string && data.phone.size() > 6;
    }

    /**
     * On update, ensures the 'creatorUserId' field cannot be changed.
     * This locks in the document's ownership permanently.
     */
    function isImmutableCreatorId() {
      return request.resource.data.creatorUserId == resource.data.creatorUserId;
    }

    /**
     * On create, validates that the new subscription request belongs to the user creating it.
     */
    function hasValidSubscriptionDataOnCreate(userId) {
      return request.resource.data.userId == userId;
    }
    
    /**
     * On create, validates that the new car booking request belongs to the user creating it.
     */
    function hasValidCarBookingDataOnCreate(userId) {
      return request.resource.data.userId == userId;
    }

    /**
     * On update, ensures the 'userId' field cannot be changed.
     * This locks in the document's ownership permanently.
     */
    function isImmutableUserId() {
      return request.resource.data.userId == resource.data.userId;
    }
    
    /**
     * On create, validates that the new 'LogementApplication' document contains an
     * 'applicantId' field that correctly matches the user's ID.
     */
    function hasValidApplicationDataOnCreate(userId) {
      return request.resource.data.applicantId == userId;
    }


    // Collection Group Rules
    // =================================
    
    /**
     * @description Allows the admin to perform a collection group query to list all transport subscriptions.
     * This is essential for the admin dashboard.
     * @path /{path=**}/transport_subscriptions/{subscriptionId}
     */
    match /{path=**}/transport_subscriptions/{subscriptionId} {
        allow get, list: if isAdmin();
    }

    // Collection Rules
    // =================================

    /**
     * @description Controls access to ID card templates. Templates are public
     *   for any signed-in user to read, but can only be created, modified,
     *   or deleted by an administrator.
     * @path /id_templates/{templateId}
     * @allow (get) An authenticated user reading a specific template.
     * @deny (create) A non-admin user trying to create a new template.
     * @principle Implements a "Public Read with Role-Based Write" access pattern.
     */
    match /id_templates/{templateId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description Controls access to the apartment listings. Listings are
     *   publicly readable by any authenticated user, but can only be managed
     *   by an administrator.
     * @path /logements/{logementId}
     * @allow (get, list) Any authenticated user can view listings.
     * @allow (create, update, delete) Only admins can manage listings.
     * @principle Separates public read access from role-based write access.
     */
    match /logements/{logementId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }

    /**
     * @description Secures the top-level user document. A user can create their
     *   own document and read/update it, but cannot read other users' documents.
     *   Listing users is forbidden to prevent user enumeration.
     * @path /users/{userId}
     * @allow (create) A new user signing up and creating their own user profile document.
     * @deny (list) An attacker trying to query the entire /users collection.
     * @principle Enforces self-service for user profiles while preventing user data leakage.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false; // Deleting user documents is typically a privileged server-side action.

      /**
       * @description Secures the user-generated ID cards. These are private and
       *   can only be accessed by the user who created them.
       * @path /users/{userId}/generated_ids/{generatedId}
       * @allow (create) An authenticated user creating a new ID card for themselves.
       * @deny (get) A user trying to access an ID card from another user's subcollection.
       * @principle Enforces strict data ownership using path-based security and validates relational integrity.
       */
      match /generated_ids/{generatedId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidGeneratedIdDataOnCreate(userId);
        allow update: if isExistingOwner(userId) && isImmutableCreatorId();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Secures user transport subscription requests for direct access.
       *   This rule handles permissions for both individual users and admins on specific
       *   documents or user-specific queries.
       * @path /users/{userId}/transport_subscriptions/{subscriptionId}
       * @principle Enforces strict data ownership while allowing for admin oversight.
       */
      match /transport_subscriptions/{subscriptionId} {
        // GET/UPDATE/DELETE: A user can access their own subscription, and an admin can access any.
        allow get, update, delete: if isOwner(userId) || isAdmin();
        
        // LIST: A user can list THEIR OWN subscriptions.
        allow list: if isOwner(userId);
        
        // CREATE: Only a user can create a subscription for themselves.
        allow create: if isOwner(userId) && hasValidSubscriptionDataOnCreate(userId);
      }
    }
    
    /**
     * @description Secures the top-level videos collection. Videos are publicly
     *   readable. Users can create videos and comment, but only modify their own content.
     * @path /videos/{videoId}
     */
    match /videos/{videoId} {
      allow get, list: if isSignedIn();

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Allow update for any signed-in user, but prevent changing the owner.
      // This is a compromise for the 'like' feature.
      allow update: if isSignedIn() && isImmutableUserId();
      
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      /**
       * @description Secures comments on videos.
       * @path /videos/{videoId}/comments/{commentId}
       */
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false; // Simplification: No editing/deleting comments
      }
    }

    /**
     * @description Secures the top-level collection for all apartment applications.
     *   Writable by any authenticated user for creating their own application.
     *   Readable only by administrators for review.
     * @path /logement_applications/{applicationId}
     * @principle Allows broad write access for submissions and restricted read access for review.
     */
    match /logement_applications/{applicationId} {
      // Any signed-in user can create an application for themselves.
      allow create: if isSignedIn() && hasValidApplicationDataOnCreate(request.auth.uid);
      // Only the admin can read, update, or delete applications.
      allow read, update, delete: if isAdmin();
      // Admins can list all applications for their dashboard.
      allow list: if isAdmin();
    }
    
    /**
     * @description Secures the top-level collection for all car rental bookings.
     *   Writable by any authenticated user for creating their own booking.
     *   Readable only by administrators for review.
     * @path /car_bookings/{bookingId}
     */
    match /car_bookings/{bookingId} {
      allow create: if isSignedIn() && hasValidCarBookingDataOnCreate(request.auth.uid);
      allow read, list, update, delete: if isAdmin();
    }

    /**
     * @description Secures the top-level collection for user inquiries.
     *   Writable by any authenticated user for submitting their own message.
     *   Readable only by administrators for review.
     * @path /inquiries/{inquiryId}
     */
    match /inquiries/{inquiryId} {
        allow create: if isSignedIn() && hasValidInquiryDataOnCreate();
        allow read, update, delete: if isAdmin();
        allow list: if isAdmin();
    }

    /**
    * @description Rules for the 'events' collection.
    */
    match /events/{eventId} {
      // Any signed-in user can read events and their comments.
      allow get, list: if isSignedIn();

      // Only an authenticated user can create an event for themselves.
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      
      // Users can't update or delete events after creation.
      allow update, delete: if false;

      /**
       * @description Rules for comments sub-collection within an event.
       */
      match /comments/{commentId} {
        // Any signed-in user can read comments.
        allow read, list: if isSignedIn();

        // Any signed-in user can create a comment for themselves.
        allow create: if isSignedIn()
                      && request.resource.data.userId == request.auth.uid;
        
        // Comments are immutable.
        allow update, delete: if false;
      }
    }
  }
}
