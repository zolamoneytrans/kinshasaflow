
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'drnduwa@gmail.com';
    }

    function isTourismAdmin() {
      return isSignedIn() && (request.auth.token.email == 'drnduwa@gmail.com' || request.auth.token.email == 'contact.congonamotema@gmail.com');
    }

    // --- COLLECTION RULES ---

    /** Application Settings */
    match /app_settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** Rules for user profiles and balances */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /star_transactions/{transactionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if false;
      }

      match /transport_subscriptions/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /pushSubscriptions/{id} {
        allow read, write: if isOwner(userId);
      }

      match /fcmTokens/{id} {
        allow read, write: if isOwner(userId);
      }
    }

    /** Adverts */
    match /adverts/{advertId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Tourism */
    match /tourism_events/{id} {
      allow read: if true;
      allow write: if isTourismAdmin();
    }
    
    match /tourism_bookings/{id} {
      allow read: if isTourismAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn();
    }

    /** Road Statuses (shared state for alerts) */
    match /road_statuses/{roadId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /** Events and Traffic Reports */
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      }
    }

    /** Notifications */
    match /notifications/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /** Daily Traffic Reports */
    match /daily_traffic_reports/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /** Logements (RBNB) */
    match /logements/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /logement_applications/{id} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.applicantId);
      allow create: if isSignedIn();
    }

    /** Car Rentals */
    match /car_bookings/{id} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn();
    }

    /** Videos Feed */
    match /videos/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      }
    }

    /** Contact Inquiries */
    match /inquiries/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    /** Administrative role assignments */
    match /admin_roles/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Global Catalog and Pricing Data */
    match /id_templates/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /star_packages/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /mobile_money_operators/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /star_earning_action_types/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /star_spending_feature_types/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}
