rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 1. Autorisation universelle en lecture pour tous les fichiers
    match /{allPaths=**} {
      allow read: if true;
    }

    // 2. Dossiers personnels pour utilisateurs connectés
    // Permet de gérer avatars, médias de chat, signalements de dangers et vidéos
    match /{folder}/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId 
                   && folder in ['avatars', 'chat', 'hazards', 'videos'];
    }

    // 3. Règle prioritaire pour le dossier tourisme (Admins)
    match /tourism/{allPaths=**} {
      allow write: if request.auth != null && 
                   (request.auth.token.email == 'drnduwa@gmail.com' || 
                    request.auth.token.email == 'contact.congonamotema@gmail.com');
    }

    // 4. Règle de secours pour l'administrateur principal sur toute la structure
    match /{allPaths=**} {
      allow write: if request.auth != null && 
                   request.auth.token.email == 'drnduwa@gmail.com';
    }
  }
}