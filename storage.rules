rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 1. Autorisation universelle en lecture pour tous les fichiers
    match /{allPaths=**} {
      allow read: if true;
    }

    // 2. Dossiers personnels pour utilisateurs connectés
    // On sépare explicitement les chemins pour une meilleure détection des permissions
    
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /chat/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /hazards/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. Règle spécifique pour le dossier tourisme (Admins)
    match /tourism/{allPaths=**} {
      allow write: if request.auth != null && 
                   (request.auth.token.email == 'drnduwa@gmail.com' || 
                    request.auth.token.email == 'contact.congonamotema@gmail.com');
    }

    // 4. Règle de secours globale pour l'administrateur principal
    match /{allPaths=**} {
      allow write: if request.auth != null && 
                   request.auth.token.email == 'drnduwa@gmail.com';
    }
  }
}