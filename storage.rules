rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Fonction simplifiée pour vérifier l'accès administrateur
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'drnduwa@gmail.com';
    }

    // --- TOURISME ---
    // Autorisation explicite pour le dossier tourism
    match /tourism/{eventId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- LOGEMENTS ---
    match /logements/{logementId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- AVATARS ---
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // --- VIDÉOS & PUBLICITÉS ---
    match /videos/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }
    
    match /adverts/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- RÈGLE PAR DÉFAUT ---
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}