rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Autorisation totale en lecture
    match /{allPaths=**} {
      allow read: if true;
    }

    // Autorisation d'écriture simplifiée au maximum pour l'admin
    // On utilise une vérification directe sans se soucier de la vérification de l'email
    match /{allPaths=**} {
      allow write: if request.auth != null && 
                   request.auth.token.email == 'drnduwa@gmail.com';
    }

    // Règle de secours spécifique pour le dossier tourisme
    match /tourism/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    // Autres dossiers
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}