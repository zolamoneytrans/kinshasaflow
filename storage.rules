rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Accès en lecture publique pour tous les fichiers (images, vidéos, audios)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Règle pour le Salon de discussion (Chat)
    match /chat/{userId}/{allPaths=**} {
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.email == 'drnduwa@gmail.com'
      );
    }

    // Règle pour les Photos de profil (Avatars)
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.email == 'drnduwa@gmail.com'
      );
    }

    // Règle pour les Signalements de dangers (Hazards)
    match /hazards/{userId}/{allPaths=**} {
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.email == 'drnduwa@gmail.com'
      );
    }

    // Règle pour le Flux Vidéos (Social)
    match /videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.email == 'drnduwa@gmail.com'
      );
    }

    // Règle pour le Dossier Tourisme (Admins uniquement)
    match /tourism/{allPaths=**} {
      allow write: if request.auth != null && (
        request.auth.token.email == 'drnduwa@gmail.com' ||
        request.auth.token.email == 'contact.congonamotema@gmail.com'
      );
    }

    // Règle de secours globale pour l'administrateur principal
    match /{allPaths=**} {
      allow write: if request.auth != null && request.auth.token.email == 'drnduwa@gmail.com';
    }
  }
}