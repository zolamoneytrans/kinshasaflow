rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Règle simplifiée et robuste pour l'administrateur
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
                   request.auth.token.email.lower() == 'drnduwa@gmail.com';
    }

    // Permission spécifique pour les dossiers utilisateurs (au cas où l'email ne suffirait pas)
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}