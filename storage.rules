rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Règle d'or pour l'administrateur : accès total sur tout le bucket
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
                   request.auth.token.email == 'drnduwa@gmail.com';
    }

    // Sécurité standard pour les avatars utilisateurs
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Sécurité standard pour les vidéos communautaires
    match /videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}