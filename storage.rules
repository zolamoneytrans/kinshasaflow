rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Règle simplifiée pour le prototype : 
    // - Tout le monde peut lire (pour afficher les images du chat immédiatement)
    // - Tout utilisateur connecté peut écrire (pour envoyer des médias)
    
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}